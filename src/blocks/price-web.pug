mixin price-web
    .price&attributes(attributes)
        each title, index in webTitles
            .services-card
                h3= title
                p.services-card__descr.text-italic!= webSubTitles[index]
                p.services-card__descr.text-bold Что входит:
                ul.services-list
                    each feature in webFeatures[index]
                        li.services-list__item
                            +svg-icon 
                            span= feature
                p.services-card__descr!= `<span>Для кого: </span> ${webDescriptions[index]}`
                p.services-card__price!= `<span>Стоимость: </span> ${webPrices[index]}.`
                +btn-consultation

//- Заголовки карточек
-
    var webTitles = ['Сложные сайты и индивидуальные веб‑сервисы', 
        'Корпоративные порталы: управление задачами и проектами',
        'Мобильные версии, PWA и системы управления задачами'
        ];
-
    var webSubTitles = [
    'Разработка масштабных веб‑решений и сопровождение действующих проектов под уникальные процессы компании.',
    'Разработка внутренних систем для планирования, контроля и командной работы, адаптированных под процессы вашей компании.',
    'Разработка мобильных интерфейсов, прогрессивных веб‑приложений и внутренних инструментов для команд.'];

//- Цены (вилка выше рынка)
- var webPrices = ['780 000 – 2 900 000 ₽.', '600 000 – 1800 000 ₽', '325 000 – 1 200 000 ₽'];

//- Краткое описание (для кого / суть)
